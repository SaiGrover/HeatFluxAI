# ─── Secrets — NEVER commit these ────────────────────────────────────────────
.env
.env.*
.cdsapirc
secrets.json
credentials.json
*_key.json

# ─── Python bytecode ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ─── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.conda/

# ─── Generated data & model artefacts ────────────────────────────────────────
# (large files — re-generated by running python main.py)
data/raw_data.csv
data/processed_data.csv
models/best_model.pkl
models/scaler.pkl
models/metrics.json
models/feature_names.json
models/outlier_stats.json

# ─── API cache (auto-regenerated) ────────────────────────────────────────────
cache/

# ─── Log files ───────────────────────────────────────────────────────────────
logs/
*.log

# ─── Claude Code project memory (conversation transcripts) ───────────────────
.claude/

# ─── Miscellaneous junk files ────────────────────────────────────────────────
*.txt
!requirements*.txt

# ─── OS / editor artefacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# ─── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Distribution / packaging ────────────────────────────────────────────────
dist/
build/
*.egg-info/
